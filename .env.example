# ===== Milvus =====
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE=rag_sum_col
MILVUS_COLLECTION=rag_summary

# ===== Model =====
ARK_API_KEY=your-ark-api-key
MODEL=your-model-name
BASE_URL=https://your-llm-endpoint/v1
EMBEDDER=your-embedding-model
GRADE_MODEL=deepseek-ai/DeepSeek-V3.2

# ===== Rerank (可选) =====
RERANK_MODEL=your-rerank-model
RERANK_BINDING_HOST=https://your-rerank-host
RERANK_API_KEY=your-rerank-api-key

# ===== Weather Tool (可选) =====
AMAP_WEATHER_API=https://restapi.amap.com/v3/weather/weatherInfo
AMAP_API_KEY=your-amap-api-key

# ===== MongoDB (迁移用) =====
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=news_db
MONGODB_COLLECTION=news
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ===== SiliconFlow (可选) =====
SILICONFLOW_API_KEY=your-api-key-here
