# ===== Docker Compose =====
# 固定 compose project name，使所有 docker compose 命令无需再加 -p milvus
COMPOSE_PROJECT_NAME=milvus

# ===== 容器 / 进程时区（Docker 内 datetime.now()、后台日志时间）=====
# 不配则 compose 默认 Asia/Shanghai；若需 UTC 可写 TZ=UTC
#TZ=Asia/Shanghai

# ===== Model =====
ARK_API_KEY=
MODEL=
BASE_URL=
GRADE_MODEL=

# ===== SiliconFlow API =====
SILICONFLOW_API_KEY=
SILICONFLOW_EMBED_MODEL=
SILICONFLOW_BASE_URL=

# ===== Rerank (可选，不配则自动降级) =====
RERANK_MODEL=
RERANK_BINDING_HOST=
RERANK_API_KEY=

# ===== Milvus =====
MILVUS_HOST=
MILVUS_PORT=
MILVUS_DATABASE=
MILVUS_COLLECTION=

# ===== Tools （可选）=====
AMAP_WEATHER_API=https://restapi.amap.com/v3/weather/weatherInfo
AMAP_API_KEY=your_amap_api_key

#===== MongoDB =====
MONGODB_HOST=
MONGODB_PORT=
MONGODB_DATABASE=
MONGODB_COLLECTION=
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ===== 嵌入式 SSO 鉴权（绑定网页 A 当前登录员工身份） =====
# SSO_MODE=mock        : 不调真实 OA，按 oassotoken 前缀生成"测试员工"，供联调
# SSO_MODE=optimus     : 调真实 OA /optimus/login/check 接口
SSO_MODE=mock
# 真实 SSO 接口地址（仅 SSO_MODE=optimus 时生效）
# 测试环境：https://testoptimus.isimcere.com/optimus/login/check
# 生产环境：http://optimusinternal.isimcere.com/optimus/login/check
SSO_URL=http://optimusinternal.isimcere.com/optimus/login/check
# SSO 调用超时秒数，默认 5
SSO_TIMEOUT=5
# 调测试环境（HTTPS 但证书不严格）时可设为 false 跳过 SSL 校验，生产请保持 true
SSO_VERIFY_SSL=true
# ticket 有效期，单位小时（默认 8h，最多 7 天 = 168h）
TICKET_TTL_HOURS=8

# ===== 后台管理 Token（admin/* 接口的 Bearer 鉴权）=====
ADMIN_TOKEN=